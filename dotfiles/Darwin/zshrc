# Conigure shell history options
HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000 # History in memory
SAVEHIST=10000 # Lines in the HISTFILE

# tmux starts login zsh, so macOS path_helper can move /usr/bin ahead of Nix.
export PATH="$HOME/.nix-profile/bin:/nix/var/nix/profiles/default/bin:$PATH"

# Set shell prompt
PS1="%F{red}»%f "

# Customize `ls` colours
export CLICOLOR=1
export LSCOLORS=ExGxFxDxCxDbDaabagacBd
# GNU-style equivalent of LSCOLORS (used by zsh completion colouring)
export LS_COLORS="di=1;34:ln=1;36:so=1;35:pi=1;33:ex=1;32:bd=1;33;41:cd=1;33;40:su=30;41:sg=30;46:tw=30;42:ow=1;31;43"

# Configure default editor to Vim
export EDITOR=vim

#setopt EXTENDED_HISTORY # Adds timestamps and exit statuses to each entry saved in HISTFILE
setopt APPEND_HISTORY # Append history, instead of overwriting it
setopt HIST_FCNTL_LOCK # Use file locking to avoid history corruption in parallel shells
setopt HIST_IGNORE_ALL_DUPS # Ignore duplicate commands
setopt HIST_IGNORE_SPACE # Ignore commands that start with a space
setopt HIST_REDUCE_BLANKS # Trim excess blanks
setopt HIST_SAVE_NO_DUPS # Prevent saving duplicates to history
setopt HIST_VERIFY # Ask for confirmation before executing a history-expanded command
setopt INC_APPEND_HISTORY # Write to the history file after each command
unsetopt SHARE_HISTORY # Keep in-memory history independent per shell session

# Ensure immediate history updates
#precmd() {
#  history -a &>/dev/null # Append history after every command
#  history -n &>/dev/null # Read new history from the history file
#}

# Shell completions user dir
[[ -d "$HOME/.zsh/zfunc" ]] || mkdir -p "$HOME/.zsh/zfunc"
fpath+=("$HOME/.zsh/zfunc")

# Use caching to speed up completion startup
[[ -d "$HOME/.zsh/cache" ]] || mkdir -p "$HOME/.zsh/cache"

zstyle ':completion::complete:*' use-cache on
zstyle ':completion::complete:*' cache-path "$HOME/.zsh/cache"

# Show completion menu when multiple options exist
zstyle ':completion:*' menu select
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}

# Fast completion (no description)
#zstyle ':completion:*' verbose no
#zstyle ':completion:*' format '%d'
zstyle ':completion:*' group-name ''

# Skip unnecessary prompt recalculations
zstyle ':completion:*' rehash true

# Completion script generation
# The blocks below write $HOME/.zsh/zfunc/_<tool> into `fpath`. They must run
# BEFORE `compinit` scans `fpath` (further down) so a freshly generated file is
# active in the same shell rather than only the next one. Each is guarded by a
# `command -v` check and cached with `test -f` so it is a no-op once generated.

# Setup environment for Rust lang
# https://rust-lang.org
if [[ -f "$HOME/.cargo/env" ]]; then
    . "$HOME/.cargo/env"
fi

# Rust lang shell completions
if command -v rustup >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_rustup" || rustup completions zsh > "$HOME/.zsh/zfunc/_rustup"
    test -f "$HOME/.zsh/zfunc/_cargo" || rustup completions zsh cargo > "$HOME/.zsh/zfunc/_cargo"
fi

# Kubernetes kubectl
# https://kubernetes.io/docs/reference/generated/kubectl/kubectl-commands
if command -v kubectl >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_kubectl" || kubectl completion zsh > "$HOME/.zsh/zfunc/_kubectl"
    if command -v difft >/dev/null 2>&1; then
        export KUBECTL_EXTERNAL_DIFF='difft'
    fi
fi

# Helm: the package manager for Kubernetes
# https://helm.sh
if command -v helm >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_helm" || helm completion zsh > "$HOME/.zsh/zfunc/_helm"
fi

# k9s: a terminal UI to interact with Kubernetes clusters
# https://k9scli.io
if command -v k9s >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_k9s" || k9s completion zsh > "$HOME/.zsh/zfunc/_k9s"
fi

# Argo CD: declarative GitOps continuous delivery for Kubernetes
# https://argo-cd.readthedocs.io
if command -v argocd >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_argocd" || argocd completion zsh > "$HOME/.zsh/zfunc/_argocd"
fi

# Cilium CLI: manage the Cilium eBPF networking/security stack
# https://cilium.io
if command -v cilium >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_cilium" || cilium completion zsh > "$HOME/.zsh/zfunc/_cilium"
fi

# Hubble: network, service and security observability for Cilium
# https://github.com/cilium/hubble
if command -v hubble >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_hubble" || hubble completion zsh > "$HOME/.zsh/zfunc/_hubble"
fi

# talosctl: manage Talos Linux Kubernetes clusters
# https://www.talos.dev
if command -v talosctl >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_talosctl" || talosctl completion zsh > "$HOME/.zsh/zfunc/_talosctl"
fi

# Jujutsu VCS
# https://github.com/jj-vcs/jj
if command -v jj >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_jj" || jj util completion zsh > ~/.zsh/zfunc/_jj
fi

# bat: a cat(1) clone with syntax highlighting and Git integration
# https://github.com/sharkdp/bat
if command -v bat >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_bat" || bat --completion zsh > ~/.zsh/zfunc/_bat
    export BAT_THEME_DARK="Nord"
fi

# Podman: daemonless container engine
# https://podman.io
if command -v podman >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_podman" || podman completion zsh > "$HOME/.zsh/zfunc/_podman"
fi

# procs: a modern replacement for ps
# https://github.com/dalance/procs
if command -v procs >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_procs" || procs --gen-completion-out zsh > "$HOME/.zsh/zfunc/_procs"
fi

# delta: a syntax-highlighting pager for git/diff output
# https://github.com/dandavison/delta
if command -v delta >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_delta" || delta --generate-completion zsh > "$HOME/.zsh/zfunc/_delta"
fi

# ripgrep: recursively search directories for a regex pattern
# https://github.com/BurntSushi/ripgrep
if command -v rg >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_rg" || rg --generate complete-zsh > "$HOME/.zsh/zfunc/_rg"
fi

# yq: a portable command-line YAML/JSON/XML processor
# https://github.com/mikefarah/yq
if command -v yq >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_yq" || yq shell-completion zsh > "$HOME/.zsh/zfunc/_yq"
fi

# Git LFS: an extension for versioning large files
# https://git-lfs.com
if command -v git-lfs >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_git-lfs" || git lfs completion zsh > "$HOME/.zsh/zfunc/_git-lfs"
fi

# difft - a structural diff that understands syntax
if command -v difft >/dev/null 2>&1; then
    # Always show both sides of the `difft`'s output. Default side-by-side uses a single column if
    # a change is exclusively additions or exclusively removals
    export DFT_DISPLAY='side-by-side-show-both'
fi

# Codex: OpenAI's command-line coding agent
# https://github.com/openai/codex
if command -v codex >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_codex" || codex completion zsh > "$HOME/.zsh/zfunc/_codex"
fi

# rumdl: a fast Markdown linter and formatter
# https://github.com/rvben/rumdl
if command -v rumdl >/dev/null 2>&1; then
    test -f "$HOME/.zsh/zfunc/_rumdl" || rumdl completions zsh > "$HOME/.zsh/zfunc/_rumdl"
fi

# Enable the completion system now that every generator above has populated
# `fpath`. `compinit` scans `fpath` once to build its table, so it must come
# after the generation blocks and before the runtime integrations below that
# call `compdef`/`complete`.
autoload -Uz +X compinit && compinit # Enable completion system
autoload -Uz +X bashcompinit && bashcompinit # Enable bash-style completion

setopt auto_menu # Show completion menu on successive tab

# Tools integration
# These hook into the live shell (sourcing widgets, `complete -C`, `compdef`)
# and therefore require `compinit`/`bashcompinit` to be loaded first.
# Command-line fuzzy finder
# https://github.com/junegunn/fzf
if command -v fzf >/dev/null 2>&1; then
    export FZF_DEFAULT_OPTS="--height=40% \
--layout=reverse \
--info=inline-right \
--color=16 \
--pointer=\"\" \
--cycle"
    . <(fzf --zsh)
fi

# zoxide: a smarter cd that ranks directories by frecency
# https://github.com/ajeetdsouza/zoxide
# `z <pattern>` jumps to the best-matching tracked dir; `zi` is interactive (fzf).
if command -v zoxide >/dev/null 2>&1; then
    eval "$(zoxide init zsh)"
fi

# HashiCorp Terraform
# https://developer.hashicorp.com/terraform
if command -v terraform >/dev/null 2>&1; then
    complete -o nospace -C "$(command -v terraform)" terraform
fi

# AWS CLI
# https://docs.aws.amazon.com/cli/latest/reference
if command -v aws >/dev/null 2>&1; then
    complete -o nospace -C "$(command -v aws_completer)" aws
fi

# 1Password CLI
# https://developer.1password.com/docs/cli
if command -v op >/dev/null 2>&1; then
    eval "$(op completion zsh)"; compdef _op op
fi

# Aliases
# Prefer Podman over Docker in this environment. Docker is largely deprecated
# here and typically requires root/VM on macOS; use rootless Podman instead.
if command -v podman >/dev/null 2>&1; then
    alias docker='podman'
fi

# If there's no `claude` tool in the system, then use temporary `npx` package.
if ! command -v claude >/dev/null 2>&1; then
    alias claude='npx @anthropic-ai/claude-code'
fi

# If there's no `codex` tool in the system, then use temporary `npx` package.
if ! command -v codex >/dev/null 2>&1; then
    alias codex='npx @openai/codex'
fi

# Functions
# Erase from top of screen to cursor.
# Redraw prompt + input buffer.
clear_above() {
    print -Pn "\e[1J"

    zle redisplay
}

# Release Ctrl+Y for userland: the tty's dsusp (default ^Y on macOS) queues
# a deferred SIGTSTP on the next read. Ctrl+Z already covers job suspension,
# so unbinding dsusp lets Ctrl+Y reach the shell and interactive programs.
[[ -t 0 ]] && stty dsusp undef

# Explicitly set default Emacs mode in a shell.
# Some utilities potentially can:
# 1. override default shell's key bindings;
# 2. override default zsh mode (eg. bindkey -v).
bindkey -e

# Remap Ctrl+L to clear terminal screen above prompt
# (temporary maybe until i found new shortcut)
zle -N clear-above clear_above
bindkey '^L' clear-above

# Avoid duplicates in PATH
typeset -U path
export PATH
