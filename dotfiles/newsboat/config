# Newsboat configuration
# Docs: https://newsboat.org/releases/2.34/docs/newsboat.html

# Fetching
refresh-on-startup            yes
auto-reload                   yes
reload-time                   30
reload-threads                8
download-retries              3
download-timeout              30

# UI
confirm-exit                  yes
cleanup-on-quit               yes
show-read-feeds               no
show-read-articles            no
goto-next-feed                no
article-sort-order            date-desc
feed-sort-order               unreadarticlecount-asc
datetime-format               "%Y-%m-%d %H:%M"
text-width                    100
scrolloff                     5

# Storage
save-path                     "~/Documents/newsboat"
max-items                     500
keep-articles-days            60

# Browser
# Default: terminal browser. Escape to GUI via macro `,o`.
browser                       "w3m %u"

# Keybindings
bind-key j                    down
bind-key k                    up
bind-key ^D                   halfpagedown
bind-key ^U                   halfpageup
bind-key g                    home
bind-key G                    end
bind-key /                    open-search
bind-key f                    article-feed
bind-key S                    save

# Macros (prefix: `,`)
# ,o — open current URL in macOS default browser
macro o set browser "open %u" ; open-in-browser ; set browser "w3m %u" -- "open in GUI browser"

# ,g — full article rendered via w3m -dump and paginated through bat
macro g set browser "w3m -dump %u | bat --paging=always --style=plain --language=md" ; open-in-browser ; set browser "w3m %u" -- "read article (w3m + bat)"

# Colors
color background              default  default
color listnormal              default  default
color listnormal_unread       color15  default  bold
color listfocus               color0   color6
color listfocus_unread        color0   color6   bold
color info                    color8   default
color article                 default  default
color end-of-text-marker      color8   default
