vim9script

# Core options only. Everything else lives in the ~/.vim runtime tree
# (symlinked from dotfiles/vim by bootstrap.sh):
#   plugin/pkg.vim           plugin manager (:PluginsUpdate)
#   plugin/statusline.vim    statusline
#   plugin/plugins-conf.vim  rust.vim, vim-go, ALE settings
#   plugin/lsp.vim           yegappan/lsp servers and format-on-save
#   plugin/mappings.vim      key mappings and helper functions
#   plugin/jenkinsfile.vim   Jenkinsfile detection for *.groovy
#   plugin/prose.vim         markdown/text/gitcommit prose settings

if &term != "linux"
    set t_Co=256
    silent! colorscheme ecs
endif

set term=${TERM}

syntax on                            # enable syntax highlighting
set nocompatible                     # enables to use Vim specific features
filetype off                         # reset filetype detection first ...
filetype plugin indent on            # ... and enable filetype detection
set omnifunc=syntaxcomplete#Complete
set tabstop=4                        # set tabs to have 4 spaces
set shiftwidth=4                     # when using the >> or << commands,
                                     # shift lines by 4 spaces
set expandtab                        # expand tabs into spaces
set smarttab
set smartindent
set number                           # show line numbers
set relativenumber                   # each line in a file is numbered relative
                                     # to the cursor’s current position to show
                                     # the distance to that line
set showmatch                        # show the matching part
                                     # of the pair for [] {} and ()
set cursorline                       # show a visual line under the cursor's current line

if v:version >= 801                  # `v: name` - variable predefined by Vim
    set cursorlineopt=number,screenline  # settings for how 'cursorline' is displayed
endif

set mouse=a                          # let Vim (not the terminal) own mouse
                                     # selection, so drag-select reads real
                                     # buffer text instead of rendered
                                     # listchars glyphs (e.g. indent guides)
set clipboard=unnamed                # yanks/deletes go straight to the
                                     # macOS system pasteboard (native
                                     # +clipboard support, no pbcopy/pbpaste
                                     # shell-out)

set fileformat=unix                  # store the file in a Unix format
set textwidth=99                     # set global width default
                                     # (markdown gets 79 via plugin/prose.vim)
set encoding=utf-8                   # set default encoding used inside Vim
set ruler                            # show the cursor position all the time
set history=50                       # keep 50 lines of command line history
set viminfo='20,\"50                 # read/write a .viminfo file, don't store more
                                     # than 50 lines of registers
set bs=indent,eol,start              # allow backspacing over everything in insert mode
set noswapfile                       # don't use swapfile
set nobackup                         # don't create backup files
set showcmd                          # show what i'm typing
set hlsearch                         # enable highlight searched patterns
set hidden                           # turn on 'hidden' mode for buffers
#set nowrap                          " do not wrap lines
                                     # allow long lines to extend as far as the line goes
set incsearch                        # while searching though a file incrementally
                                     # highlight matching characters as you type
# set ignorecase                     " ignore capital letters during search
# set smartcase                      " override the ignorecase option if searching for capital letters
                                     # this will allow to search specifically for capital letters
set showmode                         # show the mode you are on the last line.
set completeopt=menu,menuone,popup,noselect,noinsert,fuzzy # autocomplete with popup windows
set wildoptions=pum                  # Popup menu completion

# Indent guides
# Native listchars-based indent guides (Vim 9.2+).
# leadmultispace tiles a pattern across leading whitespace, redrawing
# a bar at every shiftwidth (4) columns - one per nesting level.
&list = true
&listchars = 'leadmultispace:│   ,tab:│ '
# All listchars glyphs share the SpecialKey highlight group in Vim
# (unlike Neovim's separate Whitespace/NonText groups). Dim it so the
# always-on guides stay unobtrusive; reapply on colorscheme reload the
# same way no_conceal reapplies on BufEnter.
augroup enk_indent_guides
    autocmd!
    autocmd ColorScheme * highlight SpecialKey ctermfg=238 guifg=#3a3a3a cterm=NONE gui=NONE
augroup END
highlight SpecialKey ctermfg=238 guifg=#3a3a3a cterm=NONE gui=NONE

# Override conceal level which could be set by some plugin
augroup no_conceal
    autocmd!
    autocmd BufEnter * setlocal conceallevel=0
augroup END

# Disable languages handled by dedicated plugins or where polyglot's
# non-standard syntax groups conflict with the colorscheme.
# Polyglot requires this to be set before the plugin loads, hence vimrc.
g:polyglot_disabled = ['zig', 'rust', 'go', 'markdown', 'yaml']

# Must be set before plugin/mappings.vim is sourced so <leader> resolves
# to space in every mapping defined there
g:mapleader = ' ' # by default mapleader variable is set to '\'
